# Exemplo .env para Marilan

# ─── API Configuration ─────────────────────────────────────────────────────────
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api

# ─── NFC Configuration ─────────────────────────────────────────────────────────
EXPO_PUBLIC_ENABLE_NFC=true

# ─── App Configuration ─────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_NAME=Marilan
EXPO_PUBLIC_APP_VERSION=1.0.0

# ─── Feature Flags ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_ENABLE_DEV_MODE=false
